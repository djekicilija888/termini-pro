PORT=3000
JWT_SECRET=promeni-ovo-u-dugu-tajnu-sifru
PLATFORM_NAME=Termini Pro Platforma
SUPERADMIN_EMAIL=admin@platform.local
SUPERADMIN_PASSWORD=platform123
DB_PATH=./termini-platforma-pro.db
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Termini Platforma <no-reply@termini.local>"
SMS_PROVIDER=demo
VIBER_PROVIDER=demo


# PERSISTENT DATA - važna podešavanja za Render Disk
# Na Render-u sa diskom:
DATA_DIR=/var/data
DB_PATH=/var/data/termini-platforma-pro.db

# SQLite verzija bez PostgreSQL-a.
# Radi bez DATABASE_URL.
# Upozorenje: na Render Free lokalna SQLite baza nije trajno garantovana posle redeploy-a/restarta.

# Google Play dodatni nalog:
# Produkcija: ostaviti false/nepostavljeno dok Android aplikacija ne verifikuje kupovinu.
# Test samo ako ručno želiš da simuliraš kupovinu:
ALLOW_UNVERIFIED_GOOGLE_PLAY=false
